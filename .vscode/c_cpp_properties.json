{
    "configurations": [
        {
            "name": "ROS-Noetic",
            "includePath": [
                "${workspaceFolder}/src/3dto2d/src/**",
                "${workspaceFolder}/devel/include/**",
                "${workspaceFolder}/src/**",
                "/opt/ros/noetic/include/**",
                "/usr/include/eigen3/**",
                "/usr/include/pcl-1.10/**",
                "/usr/include/opencv4/**"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/src/3dto2d/src",
                    "${workspaceFolder}/devel/include",
                    "${workspaceFolder}/src",
                    "/opt/ros/noetic/include",
                    "/usr/include/eigen3",
                    "/usr/include/pcl-1.10",
                    "/usr/include/opencv4"
                ],
                "limitSymbolsToIncludedHeaders": false
            },
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE"
            ],
            "compilerPath": "/usr/bin/g++",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64"
        }
    ],
    "version": 4
}
